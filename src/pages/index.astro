---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Personal Blog" description="Notes, projects, and essays.">
  <section class="intro">
    <p class="eyebrow">Personal Blog</p>
    <h1>Notes, projects, and essays.</h1>
    <p>
      A small corner of the web for writing in public.
    </p>
  </section>

  <section class="post-list" aria-labelledby="latest-posts">
    <h2 id="latest-posts">Latest Posts</h2>
    {
      posts.map((post) => (
        <article class="post-preview">
          <p class="date">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          </p>
          <h3>
            <a href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
        </article>
      ))
    }
  </section>
</BaseLayout>
